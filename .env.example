# ⚠️ NEVER COMMIT .env to Git! This is just a template.
# Rename this to .env and fill in your actual values

# PostgreSQL Database URL (from NeonDB)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secret Key for authentication (generate a random string)
JWT_SECRET=your-random-secret-key-here-min-32-chars

# Email Configuration (for sending reports)
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Flask Environment (development or production)
FLASK_ENV=development

# Optional: Port (only used locally, Render sets PORT automatically)
PORT=5000
